<Window x:Class="TrainingManagement.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"       
        xmlns:viewmodels="clr-namespace:TrainingManagement.WPF.ViewModels"
        xmlns:views="clr-namespace:TrainingManagement.WPF.Views"
        
        Title="Hệ Thống Quản Lý Đào Tạo - Nhóm 04" Height="600" Width="1000" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:CourseManagerViewModel}">
            <views:CourseManagerView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:TrainingPlanViewModel}">
            <views:TrainingPlanView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:CourseOfferingViewModel}">
            <views:CourseOfferingView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="MENU QUẢN LÝ" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Button Content="1. Quản lý học phần" Command="{Binding ShowCourseCommand}" Height="40" Margin="0,5" Background="#34495E" Foreground="White" BorderThickness="0"/>
                <Button Content="2. Kế hoạch đào tạo" Command="{Binding ShowPlanCommand}" Height="40" Margin="0,5" Background="#34495E" Foreground="White" BorderThickness="0"/>
                <Button Content="3. Mở lớp &amp; Phân công" Command="{Binding ShowClassCommand}" Height="40" Margin="0,5" Background="#34495E" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="10"/>
    </Grid>
</Window>